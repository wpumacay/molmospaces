# Exclude git history
.git/
.github/

# Folder-exclusions
build/
build-*/
dist/
tmp/
venv/
venv-*/
.venv/
Testing/
.cache/
.ruff_cache/
uv.lock

# Exclude settings from editors|IDEs
.vscode

# Exclude temporary python folders
*.egg-info/
*.ipynb_checkpoints/
__pycache__/

# Exclude generated typings from pybind11-stubgen
/typings

# Exclude generated folder for procthor editor build
/debug

# We don't need this for now (couldn't find where they used it)
/ros_ws

# Exclude some generated files
/assets/scenes/*
!/assets/scenes/refs/
!/assets/scenes/ithor/
/assets/objects/objaverse/


# Exclude .json files from test runs
/*.json

# Exclude .txt files from test runs
/*.txt
/*.TXT

# Exclude log files from procthor generation
procthor-10k-cant-generate
/*.json

*.zip
*.gz

*.lock

# Include the bin/ directory at the root (contains custom mujoco wheels with filament support)
!/bin
